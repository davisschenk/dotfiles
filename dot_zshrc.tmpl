HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY

autoload -Uz compinit && compinit

command -v eza >/dev/null 2>&1 && alias ls='eza' ll='eza -la --git' la='eza -a'
command -v bat >/dev/null 2>&1 && alias cat='bat --paging=never'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'
alias gd='git diff'

# Guarded: devcontainer/Coder workspaces don't always have every one of
# these tools on PATH, and an unguarded eval/source of a missing or
# too-old binary (e.g. Debian bookworm's fzf predates --zsh) crashes the
# whole shell instead of just skipping that one integration.
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh --cmd cd)"
command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh)"
command -v fzf >/dev/null 2>&1 && source <(fzf --zsh 2>/dev/null)

# zsh-syntax-highlighting must be sourced last — it wraps existing widgets,
# so anything sourced after it that also wraps widgets breaks. These two
# paths only exist on machines whose zsh plugins came from the Nix-built
# Coder workspace image (see workspace-image.nix's `zshenv`); elsewhere
# these are simply unset and the lines are skipped.
{{ if env "ZSH_AUTOSUGGESTIONS_SH" }}source "{{ env "ZSH_AUTOSUGGESTIONS_SH" }}"{{ end }}
{{ if env "ZSH_SYNTAX_HIGHLIGHTING_SH" }}source "{{ env "ZSH_SYNTAX_HIGHLIGHTING_SH" }}"{{ end }}
